<?xml version="1.0" encoding="utf-8"?>
<!-- silhouette_tests: the GTest suite — the gate every commit must pass.
     A plain console gtest binary: Visual Studio's Test Explorer discovers it
     from the solution; running the exe is the CLI path. gtest comes from the
     vcpkg manifest (autolinked). -->
