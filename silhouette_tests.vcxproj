  <ItemGroup>
    <ClCompile Include="tests\main.cpp" />
    <ClCompile Include="tests\geometry_test.cpp" />
    <ClCompile Include="tests\cheap_raster_test.cpp" />
    <ClCompile Include="tests\equivalence_test.cpp" />
    <ClCompile Include="tests\quality_raster_test.cpp" />
    <ClCompile Include="tests\quality_text_test.cpp" />
    <ClCompile Include="tests\uic_parse_test.cpp" />
    <ClCompile Include="tests\uic_schema_test.cpp" />
    <ClCompile Include="tests\uic_emit_test.cpp" />
    <ClCompile Include="src\uic\parse.cpp" />
    <ClCompile Include="src\uic\schema.cpp" />
    <ClCompile Include="src\uic\emit.cpp" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="src\uic\lex.hpp" />
    <ClInclude Include="src\uic\ast.hpp" />
    <ClInclude Include="src\uic\uic.hpp" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="silhouette.vcxproj">
      <Project>{7A3C1E20-51B2-4D9E-9C61-0F2D8A4B1102}</Project>
    </ProjectReference>
  </ItemGroup>
  <ImportGroup Label="PropertySheets">
    <Import Project="common.props" />
  </ImportGroup>
  <PropertyGroup>
    <ConfigurationType>Application</ConfigurationType>
    <ProjectGuid>{7A3C1E20-51B2-4D9E-9C61-0F2D8A4B1101}</ProjectGuid>
    <RootNamespace>silhouette_tests</RootNamespace>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <!-- slughorn is a submodule (not vcpkg): its include root is a
           project concern of the targets that compile text. -->
      <AdditionalIncludeDirectories>$(MSBuildThisFileDirectory)ext\slughorn;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
  </ItemDefinitionGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <ImportGroup Label="ExtensionSettings" />
