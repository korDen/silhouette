<?xml version="1.0" encoding="utf-8"?>
<!-- uic_lib: the markup compiler core (src/uic) as a static library —
     lexer, parser, schema pass, emit pass. Pure std. The uic CLI and
     the test suite link this; every .cpp belongs to exactly one
     project. -->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup>
    <ClCompile Include="src\uic\parse.cpp" />
    <ClCompile Include="src\uic\schema.cpp" />
    <ClCompile Include="src\uic\emit.cpp" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="src\uic\lex.hpp" />
    <ClInclude Include="src\uic\ast.hpp" />
    <ClInclude Include="src\uic\uic.hpp" />
  </ItemGroup>
  <ImportGroup Label="PropertySheets">
    <Import Project="common.props" />
  </ImportGroup>
  <PropertyGroup>
    <ConfigurationType>StaticLibrary</ConfigurationType>
    <ProjectGuid>{7A3C1E20-51B2-4D9E-9C61-0F2D8A4B1104}</ProjectGuid>
    <RootNamespace>uic_lib</RootNamespace>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <ImportGroup Label="ExtensionSettings" />
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
